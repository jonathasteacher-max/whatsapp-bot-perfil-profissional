{
  "name": "whatsapp-bot-perfil-profissional",
  "version": "1.0.0",
  "description": "Bot WhatsApp profissional para apresentação de perfil técnico - Dynamics 365 & Power Platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "whatsapp",
    "bot",
    "dynamics365",
    "power-platform",
    "typescript",
    "professional-profile"
  ],
  "author": "Jonathan",
  "license": "MIT",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^6.6.0",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "pino": "^8.18.0",
    "pino-pretty": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.16",
    "@types/qrcode-terminal": "^0.12.2",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
